# Supabase 配置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis 配置（任务队列、限流）
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_SSL=true

# 阿里云短信配置
ALIYUN_SMS_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-sms-sign-name
ALIYUN_SMS_TEMPLATE_REGISTER=SMS_000000000
ALIYUN_SMS_TEMPLATE_RESET_PWD=SMS_000000000
ALIYUN_SMS_TEMPLATE_BIND_PHONE=SMS_000000000

# 阿里云 OSS 配置
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_BUCKET_NAME=your-bucket-name
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_INTERNAL_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com
OSS_REGION=cn-hangzhou
# OSS_CDN_DOMAIN=cdn.your-domain.com

# KIE API 配置
KIE_API_KEY=your-kie-api-key
KIE_BASE_URL=https://api.kie.ai/v1

# Google Gemini API 配置
GOOGLE_API_KEY=your-google-api-key

# 阿里云 DashScope（灵积）配置
DASHSCOPE_API_KEY=your-dashscope-api-key

# Webhook 回调配置
# 开发模式：不配置 → 纯轮询（15s 间隔）
# 生产模式：配置公网地址 → 回调为主 + 轮询兜底（120s 间隔）
# CALLBACK_BASE_URL=https://api.your-domain.com
# POLL_INTERVAL_SECONDS=0  # 0=自动（有回调120s，无回调15s），可手动覆盖

# 记忆功能配置（Mem0）
# Supabase PostgreSQL 连接串（Mem0 pgvector 使用，在 Supabase 控制台 Settings > Infrastructure > Session Pooler 获取）
# SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres
# MEMORY_EXTRACTION_MODEL=qwen-plus
# MEMORY_EMBEDDING_MODEL=text-embedding-v3

# 快麦ERP 配置
KUAIMAI_APP_KEY=your-kuaimai-app-key
KUAIMAI_APP_SECRET=your-kuaimai-app-secret
KUAIMAI_ACCESS_TOKEN=your-kuaimai-access-token
KUAIMAI_REFRESH_TOKEN=your-kuaimai-refresh-token
# KUAIMAI_BASE_URL=https://gw.superboss.cc/router
# KUAIMAI_TIMEOUT=10.0

# 快麦奇门自定义接口配置（淘宝网关，需向快麦申请单独的奇门凭证）
QIMEN_APP_KEY=your-qimen-app-key
QIMEN_APP_SECRET=your-qimen-app-secret
QIMEN_CUSTOMER_ID=your-qimen-customer-id
# QIMEN_ORDER_URL=http://33c367ryyg.api.taobao.com/router/qm
# QIMEN_REFUND_URL=http://z29932hpkn.api.taobao.com/router/qm
# QIMEN_TARGET_APP_KEY=23204092

# MediaCrawler 社交媒体爬虫配置
CRAWLER_ENABLED=false
# CRAWLER_DIR=backend/external/mediacrawler
# CRAWLER_TIMEOUT=120
# CRAWLER_MAX_NOTES=30
# CRAWLER_HEADLESS=true
# CRAWLER_LOGIN_TYPE=cookie
# CRAWLER_COOKIES_XHS=your-xhs-cookie
# CRAWLER_COOKIES_DY=your-douyin-cookie
# CRAWLER_COOKIES_KS=your-kuaishou-cookie
# CRAWLER_COOKIES_BILI=your-bilibili-cookie
# CRAWLER_COOKIES_WB=your-weibo-cookie
# CRAWLER_COOKIES_TIEBA=your-tieba-cookie
# CRAWLER_COOKIES_ZHIHU=your-zhihu-cookie

# 高德 IP 定位 API（Web 服务，可选，未配置则禁用 IP 定位）
# AMAP_API_KEY=your-amap-web-api-key

# 应用配置
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS 允许的域名（逗号分隔，生产环境填实际域名）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# 限流配置
RATE_LIMIT_GLOBAL_TASKS=15
RATE_LIMIT_CONVERSATION_TASKS=5
