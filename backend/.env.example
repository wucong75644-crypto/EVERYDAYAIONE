# Supabase 配置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis 配置（任务队列、限流）
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_SSL=true

# 阿里云短信配置
ALIYUN_SMS_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-sms-sign-name
ALIYUN_SMS_TEMPLATE_REGISTER=SMS_000000000
ALIYUN_SMS_TEMPLATE_RESET_PWD=SMS_000000000
ALIYUN_SMS_TEMPLATE_BIND_PHONE=SMS_000000000

# 阿里云 OSS 配置
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_BUCKET_NAME=your-bucket-name
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_INTERNAL_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com
OSS_REGION=cn-hangzhou
# OSS_CDN_DOMAIN=cdn.your-domain.com

# KIE API 配置
KIE_API_KEY=your-kie-api-key
KIE_BASE_URL=https://api.kie.ai/v1

# Google Gemini API 配置（免费层）
GOOGLE_API_KEY=your-google-api-key

# Webhook 回调配置
# 开发模式：不配置 → 纯轮询（15s 间隔）
# 生产模式：配置公网地址 → 回调为主 + 轮询兜底（120s 间隔）
# CALLBACK_BASE_URL=https://api.your-domain.com
# POLL_INTERVAL_SECONDS=0  # 0=自动（有回调120s，无回调15s），可手动覆盖

# 应用配置
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS 允许的域名（逗号分隔，生产环境填实际域名）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# 限流配置
RATE_LIMIT_GLOBAL_TASKS=15
RATE_LIMIT_CONVERSATION_TASKS=5
