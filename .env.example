# Supabase 配置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis 配置（任务队列、限流）
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_SSL=true

# 阿里云短信配置
ALIYUN_SMS_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-sms-sign-name
ALIYUN_SMS_TEMPLATE_REGISTER=SMS_000000000
ALIYUN_SMS_TEMPLATE_RESET_PWD=SMS_000000000
ALIYUN_SMS_TEMPLATE_BIND_PHONE=SMS_000000000

# 阿里云 OSS 配置
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_BUCKET_NAME=your-bucket-name
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_INTERNAL_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com
OSS_REGION=cn-hangzhou
# OSS_CDN_DOMAIN=cdn.your-domain.com

# KIE API 配置
KIE_API_KEY=your-kie-api-key
KIE_BASE_URL=https://api.kie.ai/v1

# Webhook 回调地址（需公网可访问，未配置则退回轮询模式）
# 所有 Provider 共用同一个 base URL，通过路径区分：/api/webhook/{provider}
# CALLBACK_BASE_URL=https://everydayai.com.cn
# POLL_INTERVAL_SECONDS=0  # 0=自动（有回调120s，无回调15s），可手动覆盖

# Google Gemini API 配置（免费层）
GOOGLE_API_KEY=your-google-api-key

# 应用配置
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# 限流配置
RATE_LIMIT_GLOBAL_TASKS=15
RATE_LIMIT_CONVERSATION_TASKS=5

# 企业微信智能机器人配置（长连接模式 — 群聊）
# WECOM_BOT_ID=your-wecom-bot-id
# WECOM_BOT_SECRET=your-wecom-bot-secret

# 企微自建应用配置（URL 回调模式 — 私聊）
# WECOM_CORP_ID=your-corp-id
# WECOM_AGENT_ID=1000001
# WECOM_AGENT_SECRET=your-agent-secret
# WECOM_TOKEN=your-callback-token
# WECOM_ENCODING_AES_KEY=your-43-char-encoding-aes-key
